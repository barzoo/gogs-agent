{
  "name": "gogs-agent",
  "version": "0.2.2",
  "description": "Claude Code Skill + CLI for operating Gogs repositories",
  "type": "module",
  "bin": {
    "gogs": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && npm run generate-skill && tsx scripts/install-skill.ts",
    "generate-skill": "tsx scripts/generate-skill.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/cli.js",
    "postinstall": "tsx scripts/install-skill.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
